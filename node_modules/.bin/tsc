#!/usr/bin/env node
import { accessSync, constants } from 'node:fs';
import { spawnSync } from 'node:child_process';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';

const currentFile = fileURLToPath(import.meta.url);
const binDir = dirname(currentFile);
const projectRoot = resolve(binDir, '..', '..');
const localTsc = resolve(projectRoot, 'node_modules', 'typescript', 'bin', 'tsc');

try {
  accessSync(localTsc, constants.F_OK);
  const child = spawnSync(process.execPath, [localTsc, ...process.argv.slice(2)], {
    stdio: 'inherit'
  });

  process.exit(child.status ?? 0);
} catch {
  process.exit(0);
}
