# Required for GitHub signature verification
GITHUB_WEBHOOK_SECRET=replace-me

# Optional rotated secret support
GITHUB_WEBHOOK_PREVIOUS_SECRET=

# Webhook verification controls
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_ALLOW_MISSING_TIMESTAMP=true

# Monitor autoexecute controls
MONITOR_AUTOEXECUTE=true
MONITOR_AUTOEXECUTE_EVENTS=push,pull_request,workflow_run
MONITOR_AUTOEXECUTE_BRANCHES=main
MONITOR_AUTOEXECUTE_REPOSITORIES=owner/repo

# Health endpoint auth
WEBHOOK_HEALTH_TOKEN=local-health-token

# Local server port
PORT=3000
